# =====================================================================
# Cấu hình môi trường cho BACKEND.
# Sao chép file này thành .env và điền giá trị thật:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# =====================================================================

# API key của Google Gemini (BẮT BUỘC).
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Danh sách origin của frontend được phép gọi API (ngăn cách bởi dấu phẩy).
# Khi deploy, thay bằng URL frontend trên Railway, ví dụ:
#   https://your-frontend.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Giới hạn rate cho mỗi IP (cú pháp slowapi).
RATE_LIMIT=20/minute
